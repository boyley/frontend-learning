# ============================================================================
# Next.js（output: 'standalone'）多阶段构建 Dockerfile —— 教学示例。
# 带 .example 后缀避免被 CI/工具当成真实 Dockerfile。
# 实践时改名为 Dockerfile 放进项目根目录，并确保 next.config.js 设了
# output: 'standalone'（见 next.config.example.js）。
# 参考：https://github.com/vercel/next.js/tree/canary/examples/with-docker
# ============================================================================

# ---- 阶段 1：deps —— 只装依赖（利用缓存层，依赖不变则不重装）----------------
FROM node:20-alpine AS deps
WORKDIR /app
# 先只拷贝依赖清单，命中 Docker 层缓存：package*.json 没变就跳过 npm ci
COPY package.json package-lock.json* ./
RUN npm ci

# ---- 阶段 2：builder —— 编译 & 构建产物 ------------------------------------
FROM node:20-alpine AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY . .
# next build 会因 output:'standalone' 生成 .next/standalone/（含最小 node_modules）
RUN npm run build

# ---- 阶段 3：runner —— 最终运行镜像（只拷运行所需，镜像最小）----------------
FROM node:20-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production
# 容器里必须监听 0.0.0.0，否则容器外访问不到
ENV HOSTNAME=0.0.0.0
ENV PORT=3000

# 安全：用非 root 用户运行
RUN addgroup -g 1001 -S nodejs && adduser -u 1001 -S nextjs -G nodejs

# 关键：standalone 产物【不含】 static 与 public，必须单独拷进来，
#       否则页面缺样式 / 静态资源。
COPY --from=builder /app/public ./public
COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/.next/static ./.next/static

USER nextjs
EXPOSE 3000

# standalone 产物自带 server.js，直接 node 启动，无需完整 node_modules / next start
CMD ["node", "server.js"]
